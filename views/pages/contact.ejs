<%- include('../partials/head', { title, description, canonicalPath, cssFile, structuredData }) %>
<body>
<%- include('../partials/navbar', { active }) %>

<!-- Navbar -->
    



    <!-- Page Header -->
    <div class="page-header">
        <div class="container">
            <h1 data-aos="zoom-out" data-aos-duration="1200">Get In Touch</h1>
        </div>
    </div>

    <!-- Contact Section -->
    <section>
        <div class="container">
            <div class="contact-grid">
                <!-- Contact Form -->
                <div class="contact-form-container" data-aos="fade-right">
                    <div class="section-title" style="text-align: left; margin-bottom: 40px;">
                        <h2>Secure Communication</h2>
                        <div class="underline" style="margin: 0;"></div>
                    </div>
                    <form id="contactForm" action="/api/contact" method="post" data-web3-forms-access-key="<%= web3FormsAccessKey %>">
                        <input type="hidden" name="access_key" value="<%= web3FormsAccessKey %>">
                        <input type="text" name="website" tabindex="-1" autocomplete="off" aria-hidden="true" style="position: absolute; left: -9999px; opacity: 0;">
                        <div class="form-group">
                            <label for="name">Full Name</label>
                            <input type="text" id="name" name="name" placeholder="Enter your name" required>
                        </div>
                        <div class="form-group">
                            <label for="email">Email Address</label>
                            <input type="email" id="email" name="email" placeholder="Enter your email" required>
                        </div>
                        <div class="form-group">
                            <label for="message">Your Message</label>
                            <textarea id="message" name="message" rows="6" placeholder="How can we help you secure your future?" required></textarea>
                        </div>
                        <button type="submit" class="btn btn-primary">Send Encrypted Message</button>
                        <p id="formStatus" style="margin-top: 15px; font-size: 0.95rem; color: #aaa;"></p>
                    </form>
                </div>

                <!-- Contact Info -->
                <div class="contact-info-container" data-aos="fade-left">
                    <div class="section-title" style="text-align: left; margin-bottom: 40px;">
                        <h2>Contact Details</h2>
                        <div class="underline" style="margin: 0;"></div>
                    </div>
                    
                    <div class="info-item">
                        <div class="info-icon">
                            <i class="fas fa-envelope"></i>
                        </div>
                        <div class="info-text">
                            <h4>Email Us</h4>
                            <p>info@rynexsecurity.com</p>
                        </div>
                    </div>

                    <div class="info-item">
                        <div class="info-icon">
                            <i class="fas fa-phone"></i>
                        </div>
                        <div class="info-text">
                            <h4>Call Us</h4>
                            <p>03272873812</p>
                        </div>
                    </div>

                    <div class="info-item">
                        <div class="info-icon">
                            <i class="fas fa-map-marker-alt"></i>
                        </div>
                        <div class="info-text">
                            <h4>Our Headquarters</h4>
                            <p>Cyber Hub, Tech District, Pakistan</p>
                        </div>
                    </div>

                    <!-- Map Placeholder -->
                    <div class="map-container">
                        <div class="map-placeholder">
                            <div>
                                <i class="fas fa-satellite-dish" style="font-size: 4rem; margin-bottom: 20px; color: var(--primary); animation: pulse 2s infinite;"></i>
                                <p style="letter-spacing: 3px;">SECURE LOCATION TRACKING...</p>
                                <p style="font-size: 0.8rem; margin-top: 15px; color: #555;">[ENCRYPTED GOOGLE MAPS INTERFACE]</p>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>

            <!-- Footer -->
    



    <!-- Scripts -->

<%- include('../partials/footer') %>
<%- include('../partials/scripts', { externalScripts, localScript, contactScript }) %>
</body>
</html>
